# ШАБЛОН. Скопируй в .env и заполни только там (секреты не в git).
#   copy .env.example .env

WALLET_PRIVATE_KEY=your_solana_private_key_base58_or_json_array

RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Backpack ED25519 (балансы в GUI через GET /api/v1/capital)
BACKPACK_API_KEY=
BACKPACK_API_SECRET=

# BP token (Backpack Exchange) — официальный mint на Solana.
# Заполни после того как появятся пулы на Raydium (TGE 23.03.2026).
# Пример: BP_TOKEN_MINT=BPBHz5x7EjKkT2koyUXKfB5q4gfmmR9Mfo9opgTQhLbG
BP_TOKEN_MINT=
RAYDIUM_POOL_ID=

# Пара по умолчанию при запуске GUI (SOL/USDC | JUP/USDC | ETH/USDC | BP/USDC)
DEFAULT_PAIR=SOL/USDC

BACKPACK_API_BASE=https://api.backpack.exchange
BACKPACK_SYMBOL_SOL_USDC=SOL_USDC
BACKPACK_SYMBOL_BP_USDC=BP_USDC
BACKPACK_TAKER_FEE_PCT=0.001
ARBIT_ESTIMATED_SOL_TX_COUNT=1

# Прокси для Jupiter/httpx (одна строка):
#   socks5://user:pass@host:port  (socks5h:// в .env тоже можно — бот сам заменит на socks5:// для httpx 0.27)
#   https://user:pass@host:port
# При ошибке SSL через SOCKS: HTTPX_VERIFY_SSL=false (риск MITM — только если доверяешь прокси)
PROXY_URL=
HTTP_PROXY=
HTTPX_VERIFY_SSL=true

# Желаемая глубина стакана (API округлит к 5/10/20/50/100/500/1000)
ORDERBOOK_LEVELS=20

MIN_PROFIT_PCT=0.5
TRADE_AMOUNT_USDC=10
SLIPPAGE_BPS=200
POLL_INTERVAL_SEC=3
ENABLE_CHAIN_EXECUTE=false
DRY_RUN=true
